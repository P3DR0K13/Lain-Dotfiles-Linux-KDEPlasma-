# Carrega configs padrão do CachyOS
# source /usr/share/cachyos-fish-config/cachyos-config.fish

# ── cache ─────────────────────────────
set cache_file "/tmp/fish_sysinfo_cache"

set needs_update 0

if not test -f $cache_file
    set needs_update 1
else
    set now (date +%s)
    set file_time (stat -c %Y $cache_file 2>/dev/null)
    if test (math "$now - $file_time") -gt 600
        set needs_update 1
    end
end

# ── coleta ────────────────────────────
if test $needs_update -eq 1

    set kernel_line (uname -r)
    set shell_ver (fish --version | string replace -r '.* ' '')
    set pkg_line (count /var/lib/pacman/local/* 2>/dev/null)"(pacman)"
    set plasma_ver (plasmashell --version 2>/dev/null | string replace -r '.* ' '')
    set wm_line $XDG_SESSION_TYPE

    printf "%s\n%s\n%s\n%s\n%s\n" \
        $kernel_line \
        $shell_ver \
        $pkg_line \
        $plasma_ver \
        $wm_line > $cache_file
end

# ── leitura ───────────────────────────
set lines (string split '\n' (cat $cache_file))

set kernel_line $lines[1]
set shell_ver   $lines[2]
set pkg_line    $lines[3]
set plasma_ver  $lines[4]
set wm_line     $lines[5]

